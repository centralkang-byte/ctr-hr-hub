# ═══════════════════════════════════════════════════════════
# Staging Smoke Test Env Template
# Copy to .env.local (NOT committed) and fill in values.
# Used by: playwright.staging.config.ts
# ═══════════════════════════════════════════════════════════

# Vercel staging deployment URL
BASE_URL=https://ctr-hr-hub-staging.vercel.app

# Vercel Deployment Protection bypass token
# 발급: Vercel Dashboard → Project Settings → Deployment Protection
#      → Protection Bypass for Automation → Add Token
# 보안: 토큰 노출 시 즉시 rotate
VERCEL_AUTOMATION_BYPASS_SECRET=
