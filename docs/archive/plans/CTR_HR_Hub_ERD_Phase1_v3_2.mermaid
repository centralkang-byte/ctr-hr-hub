  string    prompt_version
  string    rejection_reason
  decimal   offered_salary
  date      offer_date
  date      expected_start_date
  string    status             "ACTIVE / WITHDRAWN / HIRED / REJECTED"
  timestamp created_at
}

interview_schedules {
