  uuid      job_category_id FK "v3.1"
  string    title
  text      description
  text      requirements
  string    employment_type
  string    status             "DRAFT / OPEN / CLOSED / CANCELLED"
  int       headcount
  date      deadline
  text      ai_generated_description "v3.1"
  string    prompt_version
  uuid      created_by FK
  timestamp created_at
  timestamp deleted_at
}

applicants {
  uuid      id PK
  string    name
  string    email
  string    phone              "ENC"
  string    resume_file_key
  string    source             "DIRECT / REFERRAL / AGENCY / JOB_BOARD"
  timestamp created_at
}

applications {
  uuid      id PK
  uuid      posting_id FK
  uuid      applicant_id FK
  string    current_stage      "APPLIED / SCREENING / INTERVIEW_1 / INTERVIEW_2 / FINAL / OFFER / HIRED / REJECTED"
