erDiagram

%% ============================================================
%% CTR HR Hub - Phase 1 ERD v3.2
%% v2.2 → v3.2 변경사항:
%%   [v3.1] 퇴직관리, 징계/상벌, 연봉/보상, 복리후생, 캘리브레이션,
%%          Pulse Survey, 근태 단말기, L&D, Succession, Payroll 확장,
%%          Attrition Risk, EMS 9블록, 온보딩 체크인, 조직 개편 등
%%   [v3.2] HR 챗봇(RAG/pgvector), Command Palette, 다면평가(360°),
%%          협업 점수, Manager Insights Hub, Task-Centric 홈
%%   테이블: 47개 → 85개 / MV: 4개 → 8개
%% ============================================================

%% ─────────────────────────────────
%% 1. 조직 / 권한
%% ─────────────────────────────────

companies {
  uuid      id PK
  string    code UK
  string    name
  string    country_code       "KR / US / CN / IN / EU / TR / MX"
  string    timezone           "Asia/Seoul 등"
  string    locale             "ko / en / zh 등"
  string    payroll_mode       "IMPORT / MANAGED"
  boolean   is_active
  timestamp created_at
  timestamp deleted_at         "soft delete"
}

departments {
  uuid      id PK
  uuid      company_id FK
  uuid      parent_id FK       "자기참조"
  string    code UK
  string    name
  int       level
  int       sort_order
  boolean   is_active
  timestamp deleted_at
}

job_grades {
  uuid      id PK
  uuid      company_id FK
  string    code
  string    name
  int       rank_order
  timestamp deleted_at
}

%% v3.1 신규
job_categories {
  uuid      id PK
  string    code UK            "OFFICE / PRODUCTION / R_AND_D / MANAGEMENT"
  string    name
  string    description
  timestamp created_at
  timestamp deleted_at
}

%% v3.1 신규
org_change_history {
  uuid      id PK
  uuid      company_id FK
  string    change_type        "CREATE / MERGE / SPLIT / CLOSE / RENAME"
  jsonb     before_state
  jsonb     after_state
  uuid      performed_by FK
  timestamp performed_at
}

roles {
  uuid      id PK
  string    name UK
  string    description
  boolean   is_system          "기본 역할 삭제 불가"
  timestamp deleted_at
}

permissions {
  uuid      id PK
  string    resource           "EMPLOYEE / ATTENDANCE 등"
  string    action             "READ / CREATE / UPDATE / DELETE / APPROVE / EXPORT"
  string    description
}

role_permissions {
  uuid      id PK
  uuid      role_id FK
  uuid      permission_id FK
}

employee_roles {
  uuid      id PK
  uuid      employee_id FK
  uuid      role_id FK
  uuid      company_id FK
  timestamp assigned_at
  timestamp revoked_at
}

%% ─────────────────────────────────
%% 2. 직원 마스터
%% ─────────────────────────────────

employees {
  uuid      id PK
  uuid      company_id FK
  uuid      department_id FK
  uuid      job_grade_id FK
  uuid      job_category_id FK "v3.1: job_categories FK"
  uuid      manager_id FK      "직속 상사 자기참조"
  string    employee_code UK
  string    first_name
  string    last_name
  string    name_local         "현지 이름"
  string    work_email UK
  string    personal_email     "ENC"
  string    phone              "ENC"
  string    emergency_contact  "ENC"
  string    photo_url
  date      birth_date         "ENC"
  string    gender
  string    nationality
  string    employment_type    "FULL_TIME / CONTRACT / DISPATCH / INTERN"
  string    status             "ACTIVE / ON_LEAVE / RESIGNED / TERMINATED"
  date      hire_date
  date      resignation_date
  date      termination_date
  timestamp onboarded_at       "v3.1: 온보딩 완료 시각"
  decimal   attrition_risk_score "v3.1: AI 이직 위험 0~100"
  string    attrition_risk_level "v3.1: LOW/MEDIUM/HIGH"
  timestamp created_at
  timestamp updated_at
  timestamp deleted_at
}

employee_auth {
  uuid      id PK
  uuid      employee_id FK UK
  string    password_hash      "Super Admin 전용"
  boolean   mfa_enabled
  string    mfa_secret
  int       failed_attempts
  timestamp locked_until
  timestamp last_login_at
}

sso_identities {
  uuid      id PK
  uuid      employee_id FK
  string    provider           "microsoft"
  string    provider_uid
  string    email
  timestamp linked_at
}

sso_sessions {
  uuid      id PK
  uuid      employee_id FK
  string    provider
  string    session_token
  string    ip_address
  string    user_agent
  string    device_type        "WEB / MOBILE"
  timestamp created_at
  timestamp revoked_at
}

employee_histories {
  uuid      id PK
  uuid      employee_id FK
  uuid      company_id FK
  string    change_type        "HIRE / PROMOTION / TRANSFER / DEMOTION / GRADE_CHANGE / DEPT_CHANGE / STATUS_CHANGE / TRANSFER_CROSS_COMPANY"
  jsonb     before_snapshot
  jsonb     after_snapshot
  uuid      from_company_id FK "v3.1: 법인간 전입 시"
  uuid      to_company_id FK   "v3.1: 법인간 전입 시"
  string    reason
  uuid      performed_by FK
  timestamp effective_date
  timestamp created_at
}

employee_documents {
  uuid      id PK
  uuid      employee_id FK
  string    doc_type           "CONTRACT / CERT / ID / OTHER"
  string    title
  string    file_key           "S3 key"
  timestamp uploaded_at
  timestamp deleted_at
}

%% v3.1 신규
profile_change_requests {
  uuid      id PK
  uuid      employee_id FK
  string    field_name
  string    old_value
  string    new_value
  string    status             "PENDING / APPROVED / REJECTED"
  string    rejection_reason
  uuid      reviewed_by FK
  timestamp reviewed_at
  timestamp created_at
}

