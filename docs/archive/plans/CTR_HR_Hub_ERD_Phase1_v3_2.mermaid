  date      goal_start
  date      goal_end
  date      eval_start
  date      eval_end
  boolean   peer_review_enabled "v3.2"
  int       peer_min_count      "v3.2: 동료 평가자 최소 수"
  int       peer_max_count      "v3.2: 동료 평가자 최대 수"
  boolean   anonymous_peer_review "v3.2: 동료 익명 여부"
  decimal   peer_weight         "v3.2: EMS 반영 가중치 0~1"
  timestamp created_at
}

