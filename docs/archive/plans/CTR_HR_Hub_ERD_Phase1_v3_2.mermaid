  string    eligibility        "ALL / FULL_TIME_ONLY / BY_GRADE / BY_TENURE"
  boolean   requires_approval
  boolean   is_active
  timestamp deleted_at
}

%% v3.1 신규
employee_benefits {
  uuid      id PK
  uuid      employee_id FK
  uuid      policy_id FK
  string    status             "ACTIVE / PENDING / EXPIRED"
  date      enrolled_date
  date      expiry_date
}

%% v3.1 신규
allowance_records {
  uuid      id PK
  uuid      employee_id FK
  uuid      company_id FK
  string    allowance_type
  decimal   amount
  string    currency
  date      effective_from
  date      effective_to
  string    reason
  uuid      approved_by FK
  timestamp created_at
}

%% ─────────────────────────────────
%% 10. Payroll
%% ─────────────────────────────────

%% v3.1 확장 (v2.2 payroll_records → payroll_runs + payroll_items)
payroll_runs {
  uuid      id PK
  uuid      company_id FK
  int       year
  int       month
  string    run_type           "REGULAR / BONUS / SEVERANCE"
  string    status             "DRAFT / CALCULATING / REVIEW / APPROVED / PAID / CANCELLED"
  decimal   total_gross
  decimal   total_deductions
  decimal   total_net
  text      ai_anomaly_summary "v3.1"
  string    prompt_version
  uuid      approved_by FK
  timestamp approved_at
  timestamp paid_at
  timestamp created_at
}

%% v3.1 신규
payroll_items {
  uuid      id PK
  uuid      run_id FK
  uuid      employee_id FK
  decimal   base_salary
  decimal   overtime_pay
  decimal   allowances
  decimal   gross_pay
  decimal   deduction_national_pension  "한국 4대보험"
  decimal   deduction_health_insurance
  decimal   deduction_employment_insurance
  decimal   deduction_income_tax
  decimal   deduction_local_tax
  decimal   total_deductions
  decimal   net_pay
  boolean   is_anomaly
  string    anomaly_type
  jsonb     adjustment
  string    adjustment_reason
  uuid      adjusted_by FK
  timestamp created_at
}

%% 기존 유지 (해외 IMPORT용)
payroll_records {
  uuid      id PK
  uuid      employee_id FK
  uuid      company_id FK
  int       year
  int       month
  string    payroll_mode       "IMPORT / MANAGED"
  string    source_system
  decimal   gross_salary
  decimal   deductions
  decimal   net_salary
  jsonb     details
  string    status             "DRAFT / CONFIRMED"
  uuid      confirmed_by FK
  timestamp confirmed_at
  timestamp created_at
}

payroll_entries {
  uuid      id PK
  uuid      payroll_record_id FK
  string    entry_type
  string    entry_name
  decimal   amount
  int       sort_order
}

payroll_insurance_kr {
