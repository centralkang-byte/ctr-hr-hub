  countryCode   String    @map("country_code")
  taxType       TaxType   @map("tax_type")
  name          String
  bracketMin    Decimal   @map("bracket_min") @db.Decimal(15, 2)
  bracketMax    Decimal?  @map("bracket_max") @db.Decimal(15, 2)
  rate          Decimal   @map("rate") @db.Decimal(8, 5)
  fixedAmount   Decimal   @default(0) @map("fixed_amount") @db.Decimal(15, 2)
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  description   String?
  isActive      Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, countryCode, taxType, bracketMin, effectiveFrom])
  @@index([companyId, countryCode])
  @@index([countryCode, taxType])
  @@map("tax_brackets")
}

// ─── Migration Job ───────────────────────────────────────

model MigrationJob {
  id               String             @id @default(uuid())
  companyId        String             @map("company_id")
  name             String
  description      String?
  sourceType       String             @map("source_type")
  dataScope        MigrationDataScope @map("data_scope")
  status           MigrationJobStatus @default(DRAFT)
  config           Json?
  totalRecords     Int                @default(0) @map("total_records")
  processedRecords Int                @default(0) @map("processed_records")
  successRecords   Int                @default(0) @map("success_records")
  errorRecords     Int                @default(0) @map("error_records")
  validationErrors Json?              @map("validation_errors")
  startedAt        DateTime?          @map("started_at")
  completedAt      DateTime?          @map("completed_at")
  createdById        String             @map("created_by")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  company Company        @relation(fields: [companyId], references: [id])
  logs    MigrationLog[]

  @@index([companyId])
  @@map("migration_jobs")
}

// ─── Migration Log ───────────────────────────────────────

model MigrationLog {
  id        String            @id @default(uuid())
  jobId     String            @map("job_id")
  level     MigrationLogLevel @default(INFO)
  message   String
  recordRef String?           @map("record_ref")
  detail    Json?
  createdAt DateTime          @default(now()) @map("created_at")

  job MigrationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("migration_logs")
}

// ================================================================
// STEP 9-3C: M365 프로비저닝 + 채용단가 + 성별급여격차
