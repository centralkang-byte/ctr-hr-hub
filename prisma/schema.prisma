  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@unique([shiftGroupId, employeeId])
  @@map("shift_group_members")
}

model ShiftSchedule {
  id             String              @id @default(uuid())
  companyId      String              @map("company_id")
  employeeId     String              @map("employee_id")
  shiftPatternId String              @map("shift_pattern_id")
  shiftGroupId   String?             @map("shift_group_id")
  workDate       DateTime            @map("work_date")
  slotIndex      Int                 @map("slot_index")
  slotName       String?             @map("slot_name")
  startTime      String              @map("start_time") // HH:mm
  endTime        String              @map("end_time")
  breakMinutes   Int                 @default(0) @map("break_minutes")
