// ================================================================
// 14. Payroll
// ================================================================

model PayrollRun {
  id              String           @id @default(uuid())
  companyId       String           @map("company_id")
  name            String           @default("")
  runType         PayrollRunType   @default(MONTHLY) @map("run_type")
  yearMonth       String           @map("year_month")       // "yyyy-MM" format
  year            Int?                                      // GP#3: 월 분리 편의를 위해
  month           Int?                                      // GP#3: 월 분리 편의를 위해
  frequency       PayrollFrequency @default(MONTHLY)
  periodStart     DateTime         @default(now()) @map("period_start")
  periodEnd       DateTime         @default(now()) @map("period_end")
  payDate         DateTime?        @map("pay_date")
  status          PayrollStatus
  totalGross      Decimal?         @map("total_gross")
  totalDeductions Decimal?         @map("total_deductions")
  totalNet        Decimal?         @map("total_net")
  headcount       Int              @default(0)
  currency        String           @default("KRW")
  importedFileKey String?          @map("imported_file_key")
  approvedById      String?          @map("approved_by")
  approvedAt      DateTime?        @map("approved_at")
  paidAt          DateTime?        @map("paid_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  createdById       String?          @map("created_by")

  // GP#3-A: 근태 마감 (STEP 1)
  attendanceClosedAt  DateTime?  @map("attendance_closed_at")
  attendanceClosedBy  String?    @map("attendance_closed_by")
  excludedEmployeeIds String[]   @default([]) @map("excluded_employee_ids")

  // GP#3-A: 수동 조정 (STEP 2.5)
  adjustmentCount Int     @default(0) @map("adjustment_count")
  adjustmentTotal Decimal @default(0) @map("adjustment_total") @db.Decimal(15, 0)

  // GP#3-A: 이상 검토 (STEP 3)
  anomalyCount         Int     @default(0) @map("anomaly_count")
  allAnomaliesResolved Boolean @default(false) @map("all_anomalies_resolved")

  // GP#3: 전월 비교용
  previousMonthRunId String? @map("previous_month_run_id")
  notes              String?

  company      Company            @relation(fields: [companyId], references: [id])
  approver     Employee?          @relation("PayrollApprover", fields: [approvedById], references: [id])
  payrollItems PayrollItem[]
  adjustments  PayrollAdjustment[]
  anomalies    PayrollAnomaly[]
  payrollApproval PayrollApproval?  @relation("PayrollApproval")

  @@index([companyId, yearMonth])
  @@index([companyId, status])
  @@map("payroll_runs")
}

model PayrollItem {
  id                 String   @id @default(uuid())
  runId              String   @map("run_id")
  employeeId         String   @map("employee_id")
  baseSalary         Decimal  @map("base_salary")
  overtimePay        Decimal  @default(0) @map("overtime_pay")
  bonus              Decimal  @default(0)
  allowances         Decimal  @default(0)
  grossPay           Decimal  @default(0) @map("gross_pay")
  deductions         Decimal  @default(0)
  netPay             Decimal  @map("net_pay")
  currency           String   @default("KRW")
  detail             Json?
  isManuallyAdjusted Boolean  @default(false) @map("is_manually_adjusted")
  adjustmentReason   String?  @map("adjustment_reason")
  createdAt          DateTime @default(now()) @map("created_at")

  run      PayrollRun @relation(fields: [runId], references: [id])
  employee Employee   @relation(fields: [employeeId], references: [id])

  @@index([runId, employeeId])
  @@map("payroll_items")
}

// ================================================================
// 14-B. GP#3: PayrollAdjustment + PayrollAnomaly
// ================================================================

// GP#3-A: 수동 조정 (소급 지급, 보너스, 오류 정정 등)
model PayrollAdjustment {
  id           String         @id @default(uuid())
  payrollRunId String         @map("payroll_run_id")
  payrollRun   PayrollRun     @relation(fields: [payrollRunId], references: [id])

  employeeId String   @map("employee_id")
  employee   Employee @relation("PayrollAdjustmentEmployee", fields: [employeeId], references: [id])

  type        AdjustmentType
  category    String           // 급여 항목 카테고리 (기본급, 수당, 복리후생 등)
  description String           // 사유/메모 (required)
  amount      Decimal          @db.Decimal(15, 0) // 양수=추가, 음수=공제

  evidenceUrl String?  @map("evidence_url") // 첨부파일 URL

  // LOA 연동 (Phase 3: 월별 급여 차액 자동 생성)
  loaId        String?  @map("loa_id")
  loaYearMonth String?  @map("loa_year_month")  // "YYYY-MM"

  leaveOfAbsence LeaveOfAbsence? @relation(fields: [loaId], references: [id])

  createdById   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([payrollRunId])
  @@index([employeeId])
  @@index([loaId])
  @@map("payroll_adjustments")
}

enum AdjustmentType {
  RETROACTIVE  // 소급 지급
  BONUS        // 경조사비, 성과급 등
  CORRECTION   // 오류 정정
  DEDUCTION    // 과지급 환수
  OTHER

  @@map("AdjustmentType")
}

// GP#3-A: 이상 감지 (데이터 생성, UI는 GP#3-B에서 구현)
model PayrollAnomaly {
  id           String       @id @default(uuid())
  payrollRunId String       @map("payroll_run_id")
  payrollRun   PayrollRun   @relation(fields: [payrollRunId], references: [id])

  employeeId String   @map("employee_id")
  employee   Employee @relation("PayrollAnomalyEmployee", fields: [employeeId], references: [id])

  ruleCode    String  @map("rule_code")     // e.g. "MOM_CHANGE_30PCT", "BAND_EXCEEDED"
  severity    AnomalySeverity
  description String

  currentValue  Decimal? @map("current_value") @db.Decimal(15, 0)
  previousValue Decimal? @map("previous_value") @db.Decimal(15, 0)
  threshold     String?  // e.g. "30%", "52h"

  // 해소
  status     AnomalyStatus @default(OPEN)
  resolvedBy String?       @map("resolved_by")
  resolvedAt DateTime?     @map("resolved_at")
  resolution String?       // "CONFIRMED_NORMAL", "CORRECTED", "WHITELISTED"

  // 화이트리스트
  whitelisted     Boolean @default(false)
  whitelistReason String? @map("whitelist_reason")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([payrollRunId])
  @@index([employeeId])
  @@map("payroll_anomalies")
}

// ─── GP#3-C: 급여 다단계 승인 (STEP 4) ───────────────────────

// TODO: Move to Settings (Payroll) — 법인별 급여 승인 체계 (역할 코드 목록)
model PayrollApproval {
  id           String               @id @default(uuid())
  payrollRunId String               @unique @map("payroll_run_id")
  payrollRun   PayrollRun           @relation("PayrollApproval", fields: [payrollRunId], references: [id])
  currentStep  Int                  @default(1) @map("current_step")
  totalSteps   Int                  @map("total_steps")
  status       PayrollApprovalStatus @default(PENDING)
  requestedBy  String               @map("requested_by")
  requestedAt  DateTime             @default(now()) @map("requested_at")
  completedAt  DateTime?            @map("completed_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  steps PayrollApprovalStep[]

  @@index([payrollRunId])
  @@map("payroll_approvals")
}

model PayrollApprovalStep {
  id           String               @id @default(uuid())
  approvalId   String               @map("approval_id")
  approval     PayrollApproval      @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  stepNumber   Int                  @map("step_number")   // 1-indexed
  roleRequired String               @map("role_required") // e.g. "HR_MANAGER", "CFO"
  approverId   String?              @map("approver_id")
  approver     Employee?            @relation("PayrollApprover2", fields: [approverId], references: [id])
  status       PayrollApprovalStepStatus @default(PENDING)
  comment      String?
  decidedAt    DateTime?            @map("decided_at")
  createdAt    DateTime             @default(now()) @map("created_at")

  @@unique([approvalId, stepNumber])
  @@index([approvalId])
  @@map("payroll_approval_steps")
}

enum PayrollApprovalStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED

  @@map("PayrollApprovalStatus")
}

enum PayrollApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("PayrollApprovalStepStatus")
}

enum AnomalySeverity {
  CRITICAL  // 법정 한도 초과 등
  WARNING   // 전월 대비 급변동 등
  INFO      // 신규입사자 첫 급여 등

  @@map("AnomalySeverity")
}

enum AnomalyStatus {
  OPEN
  RESOLVED
  WHITELISTED

  @@map("AnomalyStatus")
}

