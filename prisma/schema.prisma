enum M365ActionStatus {
  M365_PENDING
  M365_SUCCESS
  M365_FAILED

  @@map("M365ActionStatus")
}

enum RecruitmentCostType {
  AD_FEE
  AGENCY_FEE
  REFERRAL_BONUS
  ASSESSMENT_TOOL
  TRAVEL
  RELOCATION
  SIGNING_BONUS
  OTHER
}

// ─── M365 Provisioning Log ──────────────────────────────

model M365ProvisioningLog {
