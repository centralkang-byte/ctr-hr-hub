/// 사용자별 KPI 대시보드 레이아웃/필터 설정
model KpiDashboardConfig {
  id        String   @id @default(uuid())
  userId    String
  layout    Json
  filters   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@map("kpi_dashboard_configs")
