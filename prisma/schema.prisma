// ================================================================
// B1: 법인별 커스터마이징 엔진 — 설정 테이블 6개 + 공통 3개
// ================================================================

// ─── 1. 평가 설정 ─────────────────────────────────────────────
model EvaluationSetting {
  id        String   @id @default(uuid())
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])

  // 평가 방법론
  methodology String @default("MBO_BEI") @map("methodology")
  // MBO_ONLY | MBO_BEI

  // 업적등급 (JSON 배열: [{code, label, order}])
  mboGrades Json @default("[]") @map("mbo_grades")
  // 역량등급 (JSON 배열)
  beiGrades Json @default("[]") @map("bei_grades")

  // 종합등급
  overallGradeEnabled Boolean @default(true) @map("overall_grade_enabled")
  overallGradeMethod  String  @default("WEIGHTED") @map("overall_grade_method")
  // MATRIX | WEIGHTED | MANUAL
  mboWeight           Int     @default(60) @map("mbo_weight")
  beiWeight           Int     @default(40) @map("bei_weight")

  // 강제배분
  forcedDistribution     Boolean @default(false) @map("forced_distribution")
  forcedDistributionType String  @default("SOFT") @map("forced_distribution_type")
  // SOFT | HARD
  // 등급별 배분 비율 (JSON: [{gradeCode, minPct, maxPct}])
  distributionRules      Json    @default("[]") @map("distribution_rules")

  // 리뷰 프로세스 순서 (JSON 배열: ['self', 'manager', 'peer', 'calibration'])
  reviewProcessOrder Json @default("[\"self\",\"manager\",\"calibration\"]") @map("review_process_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId])
  @@index([companyId])
  @@map("evaluation_settings")
}

// ─── 2. 승진 설정 ─────────────────────────────────────────────
model PromotionSetting {
  id        String   @id @default(uuid())
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])

  // 직급 체계 (JSON 배열: [{code, label, order, trackType}])
  jobLevels Json @default("[]") @map("job_levels")

  // 승진요건 매트릭스 (JSON: [{fromLevel, toLevel, minMonths, requiredGrade}])
  promotionRules Json @default("[]") @map("promotion_rules")

  // 승진 주기
  promotionCycle String @default("ANNUAL") @map("promotion_cycle")
  // ANNUAL | SEMI_ANNUAL | QUARTERLY
  promotionMonth Int    @default(1) @map("promotion_month")
  // 1~12

  // 결재선 (JSON 배열: [{stepOrder, approverRole}])
  approvalChain Json @default("[]") @map("approval_chain")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId])
  @@index([companyId])
  @@map("promotion_settings")
}

// ─── 3. 보상 설정 ─────────────────────────────────────────────
model CompensationSetting {
  id        String   @id @default(uuid())
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])

  // 급여항목 (JSON 배열: [{code, label, type, taxable, required}])
  // type: BASE | ALLOWANCE | BONUS | DEDUCTION
  payComponents Json @default("[]") @map("pay_components")

  // 연봉밴드 (JSON: [{jobLevel, currency, min, mid, max}])
  salaryBands Json @default("[]") @map("salary_bands")

  // 인상률 매트릭스 (JSON: [{grade, bandPosition, raisePct}])
  // bandPosition: LOWER | MID | UPPER
  raiseMatrix Json @default("[]") @map("raise_matrix")

  // 성과급 규칙
  bonusType  String @default("GRADE_BASED") @map("bonus_type")
  // GRADE_BASED | PROFIT_SHARING | MIXED
  // 등급별 성과급 (JSON: [{grade, months}])
  bonusRules Json   @default("[]") @map("bonus_rules")

  // 통화
  currency String @default("KRW") @map("currency")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId])
  @@index([companyId])
  @@map("compensation_settings")
}

// ─── 4. 근태 설정 (모델만, UI는 B6) ─────────────────────────
model AttendanceSetting {
  id        String   @id @default(uuid())
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])

  // 기본 근무시간
  standardHoursPerDay Int @default(8) @map("standard_hours_per_day")
  standardDaysPerWeek Int @default(5) @map("standard_days_per_week")
  weeklyMaxHours      Int @default(52) @map("weekly_max_hours")

  // 교대제 여부
  shiftEnabled Boolean @default(false) @map("shift_enabled")

  // 유연근무 설정 (JSON: {flexEnabled, coreTimeStart, coreTimeEnd, minDailyHours})
  flexWork Json @default("{}") @map("flex_work")

  // 52시간 경고 임계값 (JSON: {caution: 44, warning: 48, blocked: 52})
  alertThresholds Json    @default("{\"caution\":44,\"warning\":48,\"blocked\":52}") @map("alert_thresholds")

  // 차단 기능 (true=KR, false=기타 법인)
  enableBlocking Boolean @default(false) @map("enable_blocking")

  // 법인 타임존
  timezone String @default("Asia/Seoul")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId])
  @@index([companyId])
  @@map("attendance_settings")
}

// ─── 52시간 경고 로그 (B6-1) ──────────────────────────────────────
model WorkHourAlert {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  employee    Employee @relation(fields: [employeeId], references: [id])
  weekStart   DateTime @map("week_start") @db.Date
  totalHours  Float    @map("total_hours")
  alertLevel  String   @map("alert_level") @db.VarChar(20) // 'caution'|'warning'|'blocked'
  threshold   Float
  isResolved  Boolean  @default(false) @map("is_resolved")
  resolvedBy  String?  @map("resolved_by")
  resolvedAt  DateTime? @map("resolved_at")
  resolveNote String?  @map("resolve_note") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([employeeId, weekStart, alertLevel])
  @@index([employeeId, weekStart])
  @@index([alertLevel, isResolved])
  @@map("work_hour_alerts")
}

// ─── 5. 휴가 설정 (모델만, UI는 B6) ─────────────────────────
model LeaveSetting {
  id        String   @id @default(uuid())
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])

  // 휴가 유형 정의 (JSON 배열: [{code, label, paidType, carryOver, maxDays}])
  leaveTypes Json @default("[]") @map("leave_types")

  // 연차 부여 규칙 (JSON: {method, basedays, accrualRule})
  annualLeaveRule Json @default("{}") @map("annual_leave_rule")

  // F-3: 마이너스 연차 설정
  allowNegativeBalance  Boolean @default(false) @map("allow_negative_balance")
  negativeBalanceLimit  Float   @default(0)     @map("negative_balance_limit")  // e.g., -3.0

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId])
  @@index([companyId])
  @@map("leave_settings")
}

// ─── 6. 온보딩 설정 (모델만, UI는 B5) ────────────────────────
model OnboardingSetting {
  id        String   @id @default(uuid())
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])

  // 체크리스트 템플릿 (JSON 배열: [{day, title, assigneeRole, category}])
  checklistTemplate Json @default("[]") @map("checklist_template")

  // 감정펄스 설정 (JSON: {frequency, questionTemplate, escalationThreshold})
  emotionPulse Json @default("{}") @map("emotion_pulse")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId])
  @@index([companyId])
  @@map("onboarding_settings")
}

// ─── 7. 환율 ──────────────────────────────────────────────────
model ExchangeRate {
  id            String   @id @default(uuid())
  year          Int      @map("year")
  month         Int      @map("month")
  fromCurrency  String   @map("from_currency")
  toCurrency    String   @default("KRW") @map("to_currency")
  rate          Decimal  @map("rate") @db.Decimal(18, 6)
  source        String   @default("manual") @map("source")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([year, month, fromCurrency, toCurrency])
  @@index([fromCurrency, toCurrency])
  @@index([year, month])
  @@map("exchange_rates")
}

// ─── 7-B. 해외 급여 업로드 매핑 ───────────────────────────────
model PayrollImportMapping {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String   @map("name")
  fileType    String   @default("xlsx") @map("file_type")
  headerRow   Int      @default(1) @map("header_row")
  mappings    Json     @map("mappings")
  currency    String   @map("currency")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company  @relation(fields: [companyId], references: [id])
  importLogs  PayrollImportLog[]

  @@map("payroll_import_mappings")
}

// ─── 7-C. 업로드 이력 ─────────────────────────────────────────
model PayrollImportLog {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  mappingId     String   @map("mapping_id")
  runId         String?  @map("run_id")
  year          Int      @map("year")
  month         Int      @map("month")
  fileName      String   @map("file_name")
  filePath      String?  @map("file_path")
  employeeCount Int      @default(0) @map("employee_count")
  totalGross    Decimal  @default(0) @map("total_gross") @db.Decimal(18, 2)
  totalNet      Decimal  @default(0) @map("total_net") @db.Decimal(18, 2)
  currency      String   @map("currency")
  status        String   @default("uploaded") @map("status")
  errorDetails  Json?    @map("error_details")
  uploadedById    String   @map("uploaded_by")
  confirmedAt   DateTime? @map("confirmed_at")
  createdAt     DateTime @default(now()) @map("created_at")

  company   Company              @relation(fields: [companyId], references: [id])
  mapping   PayrollImportMapping @relation(fields: [mappingId], references: [id])

  @@index([companyId, year, month])
  @@map("payroll_import_logs")
}

// ─── 7-D. 급여 시뮬레이션 ─────────────────────────────────────
model PayrollSimulation {
  id         String   @id @default(uuid())
  createdById  String   @map("created_by")
  type       String   @map("type")
  title      String   @map("title")
  employeeId String   @map("employee_id")
  parameters Json     @map("parameters")
  results    Json     @map("results")
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("payroll_simulations")
}

// ─── 8. 승인 플로우 ───────────────────────────────────────────
model ApprovalFlow {
  id          String   @id @default(uuid())
  name        String   @map("name")
  description String?  @map("description")
  companyId   String?  @map("company_id")
  company     Company? @relation(fields: [companyId], references: [id])

  // 모듈: benefits | recruitment | leave | promotion | general
  module   String             @map("module")
  isActive Boolean            @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  steps    ApprovalFlowStep[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([module])
  @@map("approval_flows")
}

// ─── 9. 승인 플로우 단계 ──────────────────────────────────────
model ApprovalFlowStep {
  id        String       @id @default(uuid())
  flowId    String       @map("flow_id")
  flow      ApprovalFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  stepOrder Int          @map("step_order")

  // approverType: role | specific_user
  approverType   String  @map("approver_type")
  // approverRole: direct_manager | hr_admin | dept_head | finance | ceo
  approverRole   String? @map("approver_role")
  approverUserId String? @map("approver_user_id")

  isRequired      Boolean @default(true) @map("is_required")
  // N일 후 자동 승인 (null = 없음)
  autoApproveDays Int?    @map("auto_approve_days")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([flowId])
  @@map("approval_flow_steps")
}

// ================================================================
// === B4: ATS 고도화 신규 모델 ===
// ================================================================

// ─── 채용 요청 (Requisition) ─────────────────────────────────────
model Requisition {
  id             String     @id @default(uuid())
  reqNumber      String     @unique @map("req_number") // REQ-001 형식
  companyId      String     @map("company_id")
  company        Company    @relation(fields: [companyId], references: [id])
  departmentId   String     @map("department_id")
  department     Department @relation(fields: [departmentId], references: [id])
  requesterId    String     @map("requester_id")
  requester      Employee   @relation("RequisitionRequester", fields: [requesterId], references: [id])
  positionId     String?    @map("position_id") // 기존 Position 연결 (NULL = 신규)
  position       Position?  @relation(fields: [positionId], references: [id])
  title          String     @db.VarChar(200)
  headcount      Int        @default(1)
  jobLevel       String?    @db.VarChar(20)
  employmentType String     @db.VarChar(30) // 'permanent' | 'contract' | 'intern'
  justification  String     @db.Text
  requirements   Json? // 우대사항, 필수역량 등
  urgency        String     @default("normal") @db.VarChar(20) // 'urgent' | 'normal' | 'low'
  targetDate     DateTime?  @map("target_date") @db.Date
  status         String     @default("draft") @db.VarChar(20) // 'draft' | 'pending' | 'approved' | 'rejected' | 'cancelled' | 'filled'
  approvalFlowId String?    @map("approval_flow_id")
  currentStep    Int        @default(0) @map("current_step")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  approvalRecords RequisitionApproval[]
  jobPostings     JobPosting[]

  @@index([companyId])
  @@index([departmentId])
  @@index([requesterId])
  @@index([status])
  @@map("requisitions")
}

// ─── 채용 요청 결재 기록 ──────────────────────────────────────────
model RequisitionApproval {
  id            String      @id @default(uuid())
  requisitionId String      @map("requisition_id")
  requisition   Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  stepOrder     Int         @map("step_order")
  approverId    String?     @map("approver_id") // 특정 유저 (null = 역할 기반)
  approver      Employee?   @relation("RequisitionApprover", fields: [approverId], references: [id])
  approverRole  String      @map("approver_role") @db.VarChar(50) // 'direct_manager' | 'hr_admin' | 'dept_head' | 'ceo'
  status        String      @default("pending") @db.VarChar(20) // 'pending' | 'approved' | 'rejected'
  comment       String?     @db.Text
  decidedAt     DateTime?   @map("decided_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([requisitionId])
  @@index([approverId])
  @@map("requisition_approvals")
}

// ─── Talent Pool ─────────────────────────────────────────────────
model TalentPoolEntry {
  id              String      @id @default(uuid())
  applicantId     String      @map("applicant_id")
  applicant       Applicant   @relation(fields: [applicantId], references: [id])
  sourcePostingId String?     @map("source_posting_id") // 어떤 공고에서 왔는지
  sourcePosting   JobPosting? @relation(fields: [sourcePostingId], references: [id])
  poolReason      String      @map("pool_reason") @db.VarChar(30) // 'rejected_qualified' | 'withdrawn' | 'overqualified' | 'manual'
  tags            String[]    @default([])
  notes           String?     @db.Text
  consentGiven    Boolean     @default(false) @map("consent_given")
  expiresAt       DateTime    @map("expires_at")
  status          String      @default("active") @db.VarChar(20) // 'active' | 'contacted' | 'expired' | 'hired'
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@index([applicantId])
  @@index([status])
  @@index([expiresAt])
  @@map("talent_pool_entries")
}

// ─── 후보자 중복 감지 로그 ──────────────────────────────────────────
model CandidateDuplicateLog {
  id           String    @id @default(uuid())
  candidateAId String    @map("candidate_a_id")
  candidateA   Applicant @relation("DuplicateA", fields: [candidateAId], references: [id])
  candidateBId String    @map("candidate_b_id")
  candidateB   Applicant @relation("DuplicateB", fields: [candidateBId], references: [id])
  matchType    String    @map("match_type") @db.VarChar(30) // 'email' | 'phone' | 'name_dob'
  matchScore   Float     @map("match_score") // 0.0 ~ 1.0
  resolution   String?   @db.VarChar(20) // 'merged' | 'not_duplicate' | 'pending'
  resolvedBy   String?   @map("resolved_by")
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([candidateAId])
  @@index([candidateBId])
  @@map("candidate_duplicate_logs")
}

// ================================================================
// === TRACK A: B3-2 Talent Review ===
// ================================================================

model AiEvaluationDraft {
  id           String   @id @default(uuid())
  evaluationId String   @map("evaluation_id")
  employeeId   String   @map("employee_id")
  reviewerId   String   @map("reviewer_id")
  companyId    String   @map("company_id")
  draftContent Json     @map("draft_content")
  inputSummary Json     @map("input_summary")
  status       String   @default("draft") @map("status")
  managerEdits Json?    @map("manager_edits")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employee   Employee              @relation("AiDraftEmployee", fields: [employeeId], references: [id])
  reviewer   Employee              @relation("AiDraftReviewer", fields: [reviewerId], references: [id])
  company    Company               @relation(fields: [companyId], references: [id])
  evaluation PerformanceEvaluation @relation(fields: [evaluationId], references: [id])

  @@index([evaluationId])
  @@index([employeeId])
  @@index([reviewerId])
  @@index([companyId])
  @@map("ai_evaluation_drafts")
}

model BiasDetectionLog {
  id              String   @id @default(uuid())
  evaluationCycle String   @map("evaluation_cycle")
  reviewerId      String   @map("reviewer_id")
  companyId       String   @map("company_id")
  biasType        String   @map("bias_type")
  severity        String   @map("severity")
  description     String   @db.Text
  details         Json?
  isAcknowledged  Boolean  @default(false) @map("is_acknowledged")
  createdAt       DateTime @default(now()) @map("created_at")

  reviewer Employee @relation("BiasLogReviewer", fields: [reviewerId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])

  @@index([reviewerId])
  @@index([companyId])
  @@map("bias_detection_logs")
}

// ================================================================
// B9-1: LMS Lite — 의무교육 설정 + 스킬 갭 추천
// ================================================================

// 법인별 의무교육 자동 등록 설정
model MandatoryTrainingConfig {
  id            String          @id @default(uuid())
  companyId     String?         @map("company_id")             // NULL = 전사 공통
  courseId      String          @map("course_id")
  targetGroup   String          @db.VarChar(30) @map("target_group")  // all | manager | new_hire | production
  frequency     String          @db.VarChar(20)                // annual | biennial | once
  deadlineMonth Int?            @map("deadline_month")         // 이수 마감 월 (12 = 12월)
  deletedAt      DateTime? @map("deleted_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  company Company?        @relation(fields: [companyId], references: [id])
  course  TrainingCourse  @relation(fields: [courseId], references: [id])

  @@index([companyId])
  @@index([courseId])
  @@map("mandatory_training_configs")
}

// 직원 역량 평가 (B8-3 placeholder — 스킬 갭 추천용)
model EmployeeSkillAssessment {
  id               String    @id @default(uuid())
  employeeId       String    @map("employee_id")
  competencyId     String    @map("competency_id")
  assessmentPeriod String    @default("latest") @db.VarChar(20) @map("assessment_period") // '2025-H1', '2025-Q1', 'latest'
  // B9-1 LMS 호환 — 단순 현재 레벨
  currentLevel     Int?      @map("current_level")
  // B8-3 스킬 매트릭스 — 자기평가 + 매니저 평가
  selfLevel        Int?      @map("self_level")         // 자기평가 (1~5)
  managerLevel     Int?      @map("manager_level")      // 매니저 평가 (1~5)
  finalLevel       Int?      @map("final_level")        // 최종 (매니저 우선)
  selfComment      String?   @db.Text @map("self_comment")
  managerComment   String?   @db.Text @map("manager_comment")
  assessedAt       DateTime  @default(now()) @map("assessed_at")
  assessedById     String?   @map("assessed_by_id")
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  employee   Employee   @relation("EmployeeSkillAssessments", fields: [employeeId], references: [id])
  competency Competency @relation("CompetencySkillAssessments", fields: [competencyId], references: [id])
  assessedBy Employee?  @relation("SkillAssessmentAssessor", fields: [assessedById], references: [id])

  @@unique([employeeId, competencyId, assessmentPeriod])
  @@index([employeeId])
  @@index([assessmentPeriod])
  @@map("employee_skill_assessments")
}

// === TRACK B: B8-3 스킬 매트릭스 + 갭 분석 ===
model SkillGapReport {
  id               String   @id @default(uuid())
  companyId        String   @map("company_id")
  departmentId     String?  @map("department_id")
  assessmentPeriod String   @db.VarChar(20) @map("assessment_period")
  reportData       Json     @map("report_data")
  generatedAt      DateTime @default(now()) @map("generated_at")
  generatedBy      String   @map("generated_by")

  company    Company     @relation("CompanySkillGapReports", fields: [companyId], references: [id])

  @@map("skill_gap_reports")
}

// ================================================================
// === TRACK A: B6-2 휴가 고도화 (정책엔진 + 통합 승인함) ===
// ================================================================

// ── 1. 법인별 휴가 유형 정의 ────────────────────────────────────
model LeaveTypeDef {
  id                 String   @id @default(uuid())
  companyId          String?  @map("company_id")
  code               String   @db.VarChar(30)
  name               String   @db.VarChar(100)
  nameEn             String?  @map("name_en") @db.VarChar(100)
  isPaid             Boolean  @default(true) @map("is_paid")
  allowHalfDay       Boolean  @default(true) @map("allow_half_day")
  requiresProof      Boolean  @default(false) @map("requires_proof")
  maxConsecutiveDays Int?     @map("max_consecutive_days")
  minAdvanceDays     Int?     @map("min_advance_days")      // F-3: 최소 N일 전 신청
  isActive           Boolean  @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  displayOrder       Int      @default(0) @map("display_order")

  // ── 규정 정합성 필드 (2026-03-26) ──
  category          String?  @db.VarChar(30) @map("category")           // annual, family_event, maternity, health, military, other
  subcategory       String?  @db.VarChar(30) @map("subcategory")        // celebration, condolence
  countingMethod    String   @default("business_day") @db.VarChar(20) @map("counting_method") // business_day, calendar_day
  includesHolidays  Boolean  @default(false) @map("includes_holidays")  // true: 공휴일 포함 통산 (경조)
  isSplittable      Boolean  @default(false) @map("is_splittable")      // 분할사용 가능 (배우자출산 등)
  splitDeadlineDays Int?     @map("split_deadline_days")                // 분할사용 기한 (일)
  maxPerYear        Int?     @map("max_per_year")                       // 연간 최대 사용 횟수
  paidDaysPerYear   Int?     @map("paid_days_per_year")                 // 부분유급 시 유급일수
  condolenceAmount  Int?     @map("condolence_amount")                  // 경조금 (KRW)

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  company       Company?           @relation("CompanyLeaveTypeDefs", fields: [companyId], references: [id])
  accrualRules  LeaveAccrualRule[]
  yearBalances  LeaveYearBalance[]
  leaveRequests LeaveRequest[]

  @@unique([companyId, code])
  @@map("leave_type_defs")
}

// ── 2. 연차 부여/이월 규칙 ────────────────────────────────────────
// rules JSON 구조 예시 (CTR-KR 연차):
// [
//   { "minTenureMonths": 0, "maxTenureMonths": 11, "daysPerMonth": 1, "type": "monthly" },
//   { "minTenureMonths": 12, "maxTenureMonths": 35, "daysPerYear": 15, "type": "annual" },
//   { "minTenureMonths": 36, "maxTenureMonths": null, "daysPerYear": 15, "bonusPerTwoYears": 1, "maxDays": 25, "type": "annual" }
// ]
model LeaveAccrualRule {
  id                    String       @id @default(uuid())
  leaveTypeDefId        String       @map("leave_type_def_id")
  accrualType           String       @default("annual") @map("accrual_type") @db.VarChar(30)
  accrualBasis          String       @default("calendar_year") @map("accrual_basis") @db.VarChar(30)
  rules                 Json
  carryOverType         String       @default("none") @map("carry_over_type") @db.VarChar(20)
  carryOverMaxDays      Int?         @map("carry_over_max_days")
  carryOverExpiryMonths Int?         @map("carry_over_expiry_months")
  isActive              Boolean      @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  leaveTypeDef LeaveTypeDef @relation(fields: [leaveTypeDefId], references: [id], onDelete: Cascade)

  @@map("leave_accrual_rules")
}

// ── 3. 직원별 연도별 휴가 잔여 (신 부여 엔진용) ──────────────────
// 잔여 = entitled + carriedOver + adjusted - used - pending
model LeaveYearBalance {
  id             String   @id @default(uuid())
  employeeId     String   @map("employee_id")
  leaveTypeDefId String   @map("leave_type_def_id")
  year           Int
  entitled       Float    @default(0)
  used           Float    @default(0)
  carriedOver    Float    @default(0) @map("carried_over")
  adjusted       Float    @default(0)
  pending        Float    @default(0)
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  employee     Employee     @relation("EmployeeLeaveYearBalances", fields: [employeeId], references: [id])
  leaveTypeDef LeaveTypeDef @relation(fields: [leaveTypeDefId], references: [id])

  @@unique([employeeId, leaveTypeDefId, year])
  @@index([employeeId, year])
  @@map("leave_year_balances")
}

// ── 4. 근태 도메인 통합 승인 요청 ────────────────────────────────
// requestType: 'leave' | 'overtime' | 'attendance_correction' | 'shift_change'
model AttendanceApprovalRequest {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  requesterId    String   @map("requester_id")
  requestType    String   @map("request_type") @db.VarChar(30)
  referenceId    String?  @map("reference_id")
  title          String   @db.VarChar(200)
  details        Json?
  status         String   @default("pending") @db.VarChar(20)
  approvalFlowId String?  @map("approval_flow_id")
  currentStep    Int      @default(1) @map("current_step")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  requester Employee                    @relation("AttApprovalRequester", fields: [requesterId], references: [id])
  company   Company                     @relation("CompanyAttApprovalRequests", fields: [companyId], references: [id])
  steps     AttendanceApprovalStep[]

  @@index([requesterId, status])
  @@index([companyId, status])
  @@index([companyId, requestType, status])
  @@map("attendance_approval_requests")
}

// ── 5. 통합 승인 단계 ─────────────────────────────────────────────
model AttendanceApprovalStep {
  id         String   @id @default(uuid())
  requestId  String   @map("request_id")
  stepOrder  Int      @map("step_order")
  approverId String   @map("approver_id")
  status     String   @default("pending") @db.VarChar(20)
  comment    String?  @db.Text
  decidedAt  DateTime? @map("decided_at")
  createdAt  DateTime @default(now()) @map("created_at")

  request  AttendanceApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver Employee                  @relation("AttApprovalApprover", fields: [approverId], references: [id])

  @@index([requestId, stepOrder])
  @@map("attendance_approval_steps")
}

// ================================================================
// === TRACK A: B7-1a 한국법인 급여 계산 엔진 ===
// ================================================================

// ── 1. 4대보험 요율 (연도별, 매년 업데이트) ─────────────────────
// type: 'national_pension' | 'health_insurance' | 'long_term_care'
//       'employment_insurance' | 'industrial_accident'
// long_term_care.employeeRate = 건강보험료 × rate (특수 계산 방식)
model InsuranceRate {
  id           String   @id @default(uuid())
  year         Int
  type         String   @db.VarChar(30)   // 보험 종류
  employeeRate Float    @map("employee_rate")   // 근로자 부담률 (%)
  employerRate Float    @map("employer_rate")   // 사업주 부담률 (%)
  upperLimit   Float?   @map("upper_limit")     // 보수월액 상한 (원)
  lowerLimit   Float?   @map("lower_limit")     // 보수월액 하한 (원)
  notes        String?  @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([year, type])
  @@map("insurance_rates")
}

// ── 2. 비과세 한도 (연도별) ──────────────────────────────────────
// code: 'meal_allowance' | 'vehicle_allowance' | 'childcare' 등
model NontaxableLimit {
  id           String   @id @default(uuid())
  year         Int
  code         String   @db.VarChar(30)
  name         String   @db.VarChar(100)
  monthlyLimit Int      @map("monthly_limit")   // 월 한도 (원)
  annualLimit  Int?     @map("annual_limit")    // 연 한도 (null이면 월×12)
  isActive     Boolean  @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([year, code])
  @@map("nontaxable_limits")
}

// ── 3. 급여명세서 발급 추적 ──────────────────────────────────────
model Payslip {
  id            String    @id @default(uuid())
  payrollItemId String    @map("payroll_item_id")
  employeeId    String    @map("employee_id")
  companyId     String    @map("company_id")
  year          Int
  month         Int
  pdfPath       String?   @map("pdf_path") @db.VarChar(500)
  isViewed      Boolean   @default(false) @map("is_viewed")
  viewedAt      DateTime? @map("viewed_at")
  sentViaEmail  Boolean   @default(false) @map("sent_via_email")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  employee Employee @relation("EmployeePayslips", fields: [employeeId], references: [id])
  company  Company  @relation("CompanyPayslips", fields: [companyId], references: [id])

  @@unique([payrollItemId])
  @@index([employeeId, year, month])
  @@index([companyId, year, month])
  @@map("payslips")
}

// ================================================================
// B7-1b: 연말정산 (Year-End Tax Settlement)
// ================================================================

// ── 연말정산 공제 항목 설정 (매년 업데이트) ──
model YearEndDeductionConfig {
  id           String   @id @default(uuid())
  year         Int
  category     String   @db.VarChar(30)    // 'income_deduction' | 'tax_credit'
  code         String   @db.VarChar(50)    // 'personal', 'pension', etc.
  name         String   @db.VarChar(100)
  rules        Json
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([year, code])
  @@map("year_end_deduction_configs")
}

// ── 과세표준 세율 구간 ──
model IncomeTaxRate {
  id                   String   @id @default(uuid())
  year                 Int
  minAmount            BigInt   @map("min_amount")
  maxAmount            BigInt?  @map("max_amount")
  rate                 Float
  progressiveDeduction BigInt   @map("progressive_deduction")
  createdAt            DateTime @default(now()) @map("created_at")

  @@unique([year, minAmount])
  @@index([year, minAmount])
  @@map("income_tax_rates")
}

// ── 직원별 연말정산 ──
model YearEndSettlement {
  id                    String    @id @default(uuid())
  employeeId            String    @map("employee_id")
  year                  Int
  status                String    @default("not_started") @db.VarChar(20)
  totalSalary           BigInt    @default(0) @map("total_salary")
  earnedIncomeDeduction BigInt    @default(0) @map("earned_income_deduction")
  earnedIncome          BigInt    @default(0) @map("earned_income")
  incomeDeductions      Json?     @map("income_deductions")
  totalIncomeDeduction  BigInt    @default(0) @map("total_income_deduction")
  taxableBase           BigInt    @default(0) @map("taxable_base")
  taxRate               Float?    @map("tax_rate")
  calculatedTax         BigInt    @default(0) @map("calculated_tax")
  taxCredits            Json?     @map("tax_credits")
  totalTaxCredit        BigInt    @default(0) @map("total_tax_credit")
  determinedTax         BigInt    @default(0) @map("determined_tax")
  prepaidTax            BigInt    @default(0) @map("prepaid_tax")
  finalSettlement       BigInt    @default(0) @map("final_settlement")
  localTaxSettlement    BigInt    @default(0) @map("local_tax_settlement")
  submittedAt           DateTime? @map("submitted_at")
  confirmedAt           DateTime? @map("confirmed_at")
  confirmedBy           String?   @map("confirmed_by")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  employee           Employee           @relation("EmployeeYearEndSettlements", fields: [employeeId], references: [id])
  dependents         YearEndDependent[]
  deductions         YearEndDeduction[]
  documents          YearEndDocument[]
  withholdingReceipt WithholdingReceipt? @relation("SettlementWithholdingReceipt")

  @@unique([employeeId, year])
  @@map("year_end_settlements")
}

// ── 부양가족 ──
model YearEndDependent {
  id                  String    @id @default(uuid())
  settlementId        String    @map("settlement_id")
  relationship        String    @db.VarChar(20)
  name                String    @db.VarChar(50)
  residentNumber      String?   @map("resident_number") @db.VarChar(20)
  birthDate           DateTime? @db.Date @map("birth_date")
  isDisabled          Boolean   @default(false) @map("is_disabled")
  isSenior            Boolean   @default(false) @map("is_senior")
  isSingleParent      Boolean   @default(false) @map("is_single_parent")
  deductionAmount     Int       @default(1500000) @map("deduction_amount")
  additionalDeduction Int       @default(0) @map("additional_deduction")
  createdAt           DateTime  @default(now()) @map("created_at")

  settlement YearEndSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@map("year_end_dependents")
}

// ── 공제 항목 상세 (직원 입력) ──
model YearEndDeduction {
  id               String   @id @default(uuid())
  settlementId     String   @map("settlement_id")
  configCode       String   @map("config_code") @db.VarChar(50)
  category         String   @db.VarChar(30)
  name             String   @db.VarChar(100)
  inputAmount      BigInt   @default(0) @map("input_amount")
  deductibleAmount BigInt   @default(0) @map("deductible_amount")
  details          Json?
  source           String   @default("manual") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  settlement YearEndSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@map("year_end_deductions")
}

// ── 제출 서류 ──
model YearEndDocument {
  id           String   @id @default(uuid())
  settlementId String   @map("settlement_id")
  documentType String   @map("document_type") @db.VarChar(50)
  fileName     String   @map("file_name") @db.VarChar(200)
  filePath     String   @map("file_path") @db.VarChar(500)
  parsedData   Json?    @map("parsed_data")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  settlement YearEndSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@map("year_end_documents")
}

// ── 원천징수영수증 ──
model WithholdingReceipt {
  id           String   @id @default(uuid())
  settlementId String   @map("settlement_id")
  employeeId   String   @map("employee_id")
  year         Int
  pdfPath      String?  @map("pdf_path") @db.VarChar(500)
  issuedAt     DateTime @default(now()) @map("issued_at")

  settlement YearEndSettlement @relation("SettlementWithholdingReceipt", fields: [settlementId], references: [id])
  employee   Employee          @relation("EmployeeWithholdingReceipts", fields: [employeeId], references: [id])

  @@unique([settlementId])
  @@map("withholding_receipts")
}

// ================================================================
// B10-1: HR 예측 애널리틱스 (이직위험 + 번아웃 + 팀 건강도)
// ================================================================

// 이직 위험 점수
model TurnoverRiskScore {
  id           String   @id @default(uuid())
  employeeId   String   @map("employee_id")
  calculatedAt DateTime @default(now()) @map("calculated_at")
  overallScore Float    @map("overall_score") // 0~100 (높을수록 위험)
  riskLevel    String   @db.VarChar(20) @map("risk_level") // 'low' | 'medium' | 'high' | 'critical' | 'insufficient_data'
  signals      Json // [{ signal, weight, score, rawData, available }]
  topFactors   String[] @default([]) @map("top_factors")
  createdAt    DateTime @default(now()) @map("created_at")

  employee Employee @relation("EmployeeTurnoverRiskScores", fields: [employeeId], references: [id])

  @@index([employeeId, calculatedAt])
  @@map("turnover_risk_scores")
}

// 번아웃 점수
model BurnoutScore {
  id           String   @id @default(uuid())
  employeeId   String   @map("employee_id")
  calculatedAt DateTime @default(now()) @map("calculated_at")
  overallScore Float    @map("overall_score") // 0~100
  riskLevel    String   @db.VarChar(20) @map("risk_level") // 'low' | 'medium' | 'high' | 'critical'
  indicators   Json // [{ indicator, weight, score, available }]
  createdAt    DateTime @default(now()) @map("created_at")

  employee Employee @relation("EmployeeBurnoutScores", fields: [employeeId], references: [id])

  @@index([employeeId, calculatedAt])
  @@map("burnout_scores")
}

// 팀 건강도 점수
model TeamHealthScore {
  id           String   @id @default(uuid())
  departmentId String   @map("department_id")
  companyId    String   @map("company_id")
  calculatedAt DateTime @default(now()) @map("calculated_at")
  overallScore Float    @map("overall_score") // 0~100 (높을수록 건강)
  metrics      Json // { avgSentiment, turnoverRate, leaveUsageRate, overtimeVariance, exitSatisfaction }
  riskLevel    String   @db.VarChar(20) @map("risk_level") // 'healthy' | 'caution' | 'at_risk'
  memberCount  Int      @map("member_count")
  createdAt    DateTime @default(now()) @map("created_at")

  department Department @relation("DepartmentTeamHealthScores", fields: [departmentId], references: [id])
  company    Company    @relation("CompanyTeamHealthScores", fields: [companyId], references: [id])

  @@index([departmentId, calculatedAt])
  @@map("team_health_scores")
}

// 분석 스냅샷 (추이 분석용)
model AnalyticsSnapshot {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  snapshotDate DateTime @db.Date @map("snapshot_date")
  type         String   @db.VarChar(30) // 'turnover_risk' | 'burnout' | 'team_health'
  data         Json // 스냅샷 데이터 (분포 집계 등)
  createdAt    DateTime @default(now()) @map("created_at")

  company Company @relation("CompanyAnalyticsSnapshots", fields: [companyId], references: [id])

  @@unique([companyId, snapshotDate, type])
  @@map("analytics_snapshots")
}

// 분석 가중치 설정 (법인별 조정 가능)
model AnalyticsConfig {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  configType String   @db.VarChar(30) @map("config_type") // 'turnover_weights' | 'burnout_weights' | 'team_health_weights'
  config     Json // { signals: [{ key, weight, threshold }] }
  isActive   Boolean  @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company Company @relation("CompanyAnalyticsConfigs", fields: [companyId], references: [id])

  @@unique([companyId, configType])
  @@map("analytics_configs")
}

