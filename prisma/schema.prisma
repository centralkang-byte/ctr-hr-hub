// ================================================================
// GP#4: Performance Pipeline Foundation
// ================================================================

model PerformanceReview {
  id                  String           @id @default(uuid())
  cycleId             String           @map("cycle_id")
  employeeId          String           @map("employee_id")
  companyId           String           @map("company_id")
  status              ReviewStatus     @default(NOT_STARTED)

  // Two-track grade preservation (Design Spec Section 11)
  originalGrade       PerformanceGrade?  @map("original_grade")
  finalGrade          PerformanceGrade?  @map("final_grade")
  calibrationNote     String?            @map("calibration_note")

  // Overdue flags (Design Spec Section 3)
  overdueFlags        Json               @default("[]") @map("overdue_flags")

  // Result notification (Design Spec Section 12)
  notifiedAt          DateTime?          @map("notified_at")
  notifiedBy          String?            @map("notified_by")
  acknowledgedAt      DateTime?          @map("acknowledged_at")
  isAutoAcknowledged  Boolean            @default(false) @map("is_auto_acknowledged")

  // Calculated scores
  mboScore            Decimal?           @db.Decimal(5, 2) @map("mbo_score")
  beiScore            Decimal?           @db.Decimal(5, 2) @map("bei_score")
  totalScore          Decimal?           @db.Decimal(5, 2) @map("total_score")

  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  cycle               PerformanceCycle   @relation(fields: [cycleId], references: [id])
  employee            Employee           @relation("ReviewEmployee", fields: [employeeId], references: [id])
  notifier            Employee?          @relation("ReviewNotifier", fields: [notifiedBy], references: [id])
  company             Company            @relation(fields: [companyId], references: [id])

  @@unique([cycleId, employeeId])
  @@index([cycleId])
  @@index([employeeId])
  @@index([companyId])
  @@map("performance_reviews")
}

model PeerReviewAnswer {
  id                    String    @id @default(uuid())
  nominationId          String    @unique @map("nomination_id")

  // CTR Core Values scores (1-5 each)
  scoreChallenge        Int       @map("score_challenge")
  scoreTrust            Int       @map("score_trust")
  scoreResponsibility   Int       @map("score_responsibility")
  scoreRespect          Int       @map("score_respect")

  // Comments per value (optional per item, overall required)
  commentChallenge      String?   @map("comment_challenge")
  commentTrust          String?   @map("comment_trust")
  commentResponsibility String?   @map("comment_responsibility")
  commentRespect        String?   @map("comment_respect")
  overallComment        String    @map("overall_comment")

  submittedAt           DateTime  @default(now()) @map("submitted_at")

  nomination            PeerReviewNomination @relation(fields: [nominationId], references: [id])

  @@map("peer_review_answers")
}

model EmployeeLevelMapping {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  jobGradeCode  String   @map("job_grade_code")
  levelCode     String   @map("level_code")  // L1 | L2 | L3 | L4 | L5 | EXEC
  mboWeight     Int?     @map("mbo_weight")  // Level-specific override (null = cycle default)
  beiWeight     Int?     @map("bei_weight")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company       Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, jobGradeCode])
  @@map("employee_level_mappings")
}

// ================================================================
// F-2: Approval Delegation (승인 권한 위임)
// ================================================================

enum DelegationScope {
  LEAVE_ONLY
  ALL
}

enum DelegationStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

model ApprovalDelegation {
  id           String           @id @default(uuid())
  delegatorId  String           @map("delegator_id")
  delegateeId  String           @map("delegatee_id")
  companyId    String           @map("company_id")
  scope        DelegationScope  @default(LEAVE_ONLY)
  status       DelegationStatus @default(ACTIVE)
  reason       String?
  startDate    DateTime         @map("start_date")
  endDate      DateTime         @map("end_date")
  revokedAt    DateTime?        @map("revoked_at")
  revokedBy    String?          @map("revoked_by")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  delegator Employee @relation("DelegationDelegator", fields: [delegatorId], references: [id])
  delegatee Employee @relation("DelegationDelegatee", fields: [delegateeId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])

  @@index([delegatorId, status])
  @@index([delegateeId, status])
  @@index([companyId, status, startDate, endDate])
  @@map("approval_delegations")
}

// ================================================================
// G-2: AI Report
// ================================================================

enum AiReportStatus {
  GENERATING
  GENERATED
  FAILED
}

model AiReport {
  id          String         @id @default(uuid())
  companyId   String?        @map("company_id")
  period      String         // "2026-03" (year-month)
  content     String         @default("")
  metadata    Json?          // { tokensUsed, model, generatedAt, kpiSnapshot }
  status      AiReportStatus @default(GENERATING)
  generatedBy String?        @map("generated_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  company     Company?       @relation(fields: [companyId], references: [id])

  @@unique([companyId, period])
  @@index([period])
  @@map("ai_reports")
}

// B-2a: Work Location model
model WorkLocation {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  code         String
  name         String
  nameEn       String?  @map("name_en")
  country      String   // ISO 3166-1 alpha-2: "KR", "CN", "US", "MX", "VN", "RU", "PL", "CL", "TH", "ID"
  city         String?
  timezone     String?  // e.g., "Asia/Seoul", "America/Detroit", "America/Monterrey"
  address      String?
  locationType String?  @map("location_type") // "OFFICE", "PLANT", "WAREHOUSE", "BRANCH_OFFICE"
  deletedAt      DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company     Company              @relation(fields: [companyId], references: [id])
  assignments EmployeeAssignment[]

  @@unique([companyId, code])
  @@map("work_locations")
}

// ================================================================
// Certificate Request (증명서 발급 요청)
// ================================================================

model CertificateRequest {
  id             String                    @id @default(uuid())
  employeeId     String                    @map("employee_id")
  companyId      String                    @map("company_id")
  type           CertificateRequestType
  purpose        String?
  status         CertificateRequestStatus  @default(REQUESTED)
  rejectedReason String?                   @map("rejected_reason")
  issuedFileKey  String?                   @map("issued_file_key")
  requestedAt    DateTime                  @default(now()) @map("requested_at")
  approvedAt     DateTime?                 @map("approved_at")
  issuedAt       DateTime?                 @map("issued_at")
  approvedById     String?                   @map("approved_by")

  employee Employee  @relation("CertRequestEmployee", fields: [employeeId], references: [id])
  company  Company   @relation(fields: [companyId], references: [id])
  approver Employee? @relation("CertRequestApprover", fields: [approvedById], references: [id])

  @@index([employeeId])
  @@index([companyId, status])
  @@map("certificate_requests")
}

// ================================================================
// B1: Leave of Absence (휴직) — 육아/질병/가족돌봄/병역 등
// ================================================================

/// 법인별 휴직 유형 정의
model LeaveOfAbsenceType {
  id                       String    @id @default(uuid())
  companyId                String    @map("company_id")
  code                     String                          // PARENTAL, MATERNITY, FAMILY_CARE, MEDICAL, WORK_INJURY, MILITARY, PERSONAL, STUDY, ...
  name                     String                          // "육아휴직"
  nameEn                   String?   @map("name_en")       // "Parental Leave"
  category                 String                          // STATUTORY | CONTRACTUAL
  maxDurationDays          Int?      @map("max_duration_days")   // null = 무제한 (산재 등)
  payType                  String    @default("UNPAID") @map("pay_type")    // PAID | UNPAID | PARTIAL | INSURANCE | MIXED
  payRate                  Int?      @map("pay_rate")            // 급여 비율 % (null = N/A)
  paySource                String?   @map("pay_source")          // EMPLOYER | GOVERNMENT | INSURANCE | MIXED
  eligibilityMonths        Int?      @map("eligibility_months")  // 최소 근속 요건 (개월)
  countsAsService          Boolean   @default(true)  @map("counts_as_service")     // 근속기간 산입
  countsAsAttendance       Boolean   @default(false) @map("counts_as_attendance")  // 연차 출근일수 산입
  splittable               Boolean   @default(false)             // 분할 사용 가능
  maxSplitCount            Int?      @map("max_split_count")
  requiresProof            Boolean   @default(false) @map("requires_proof")
  proofDescription         String?   @map("proof_description")   // "의사 진단서, 출생증명서"
  advanceNoticeDays        Int?      @map("advance_notice_days") // 사전 신청 기한 (일)
  reinstatementGuaranteed  Boolean   @default(false) @map("reinstatement_guaranteed") // 원직 복귀 보장
  sortOrder                Int       @default(0) @map("sort_order")
  isActive                 Boolean   @default(true) @map("is_active")
  deletedAt                DateTime? @map("deleted_at")

  company  Company            @relation(fields: [companyId], references: [id])
  records  LeaveOfAbsence[]

  @@unique([companyId, code])
  @@map("leave_of_absence_types")
}

/// 휴직 기록 (6-state 워크플로: REQUESTED → APPROVED → ACTIVE → RETURN_REQUESTED → COMPLETED)
model LeaveOfAbsence {
  id                 String    @id @default(uuid())
  employeeId         String    @map("employee_id")
  companyId          String    @map("company_id")
  typeId             String    @map("type_id")

  // 기간
  startDate          DateTime  @map("start_date") @db.Date
  expectedEndDate    DateTime? @map("expected_end_date") @db.Date   // 예정 복귀일
  actualEndDate      DateTime? @map("actual_end_date") @db.Date     // 실제 복귀일

  // 상태
  status             String    @default("REQUESTED")
  // REQUESTED → APPROVED → ACTIVE → RETURN_REQUESTED → COMPLETED
  //                                                   ↘ CANCELLED
  //           → REJECTED

  // 급여 (유형 기본값 오버라이드)
  payType            String?   @map("pay_type")
  payRate            Int?      @map("pay_rate")

  // 사유 & 증빙
  reason             String?
  proofFileUrl       String?   @map("proof_file_url")

  // 승인
  requestedAt        DateTime  @default(now()) @map("requested_at")
  approvedById         String?   @map("approved_by")
  approvedAt         DateTime? @map("approved_at")
  rejectedBy         String?   @map("rejected_by")
  rejectedAt         DateTime? @map("rejected_at")
  rejectionReason    String?   @map("rejection_reason")

  // 복직
  returnPositionId   String?   @map("return_position_id")  // 복귀 직위 (null = 원직)
  returnNotes        String?   @map("return_notes")

  // Assignment 연동
  loaAssignmentId    String?   @map("loa_assignment_id")    // ON_LEAVE 발령 ID
  returnAssignmentId String?   @map("return_assignment_id") // 복직 발령 ID

  // 분할 사용 (splittable인 경우)
  splitSequence      Int       @default(1) @map("split_sequence")
  parentId           String?   @map("parent_id")

  // 메타
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  // Relations
  employee  Employee             @relation("LOAEmployee", fields: [employeeId], references: [id])
  company   Company              @relation(fields: [companyId], references: [id])
  type      LeaveOfAbsenceType   @relation(fields: [typeId], references: [id])
  approver  Employee?            @relation("LOAApprover", fields: [approvedById], references: [id])
  rejecter  Employee?            @relation("LOARejecter", fields: [rejectedBy], references: [id])
  parent    LeaveOfAbsence?      @relation("LOASplit", fields: [parentId], references: [id])
  splits    LeaveOfAbsence[]     @relation("LOASplit")

  payrollAdjustments PayrollAdjustment[]

  @@index([employeeId])
  @@index([companyId, status])
  @@index([startDate])
  @@map("leave_of_absences")
}
