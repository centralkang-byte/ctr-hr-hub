  status         ShiftScheduleStatus @default(SCHEDULED)
  note           String?
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  company      Company      @relation(fields: [companyId], references: [id])
  employee     Employee     @relation("ShiftScheduleEmployee", fields: [employeeId], references: [id])
  shiftPattern ShiftPattern @relation(fields: [shiftPatternId], references: [id])
  shiftGroup   ShiftGroup?  @relation(fields: [shiftGroupId], references: [id])

