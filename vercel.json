{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':(exclude)docs/**' ':(exclude)*.md' ':(exclude).claude/**' ':(exclude).codex/**' ':(exclude)_design-reference/**' ':(exclude)e2e/**'",
  "crons": [
    { "path": "/api/v1/cron/nudge-batch", "schedule": "0 1 * * *" },
    { "path": "/api/v1/cron/loa-return-reminder", "schedule": "0 0 * * *" },
    { "path": "/api/v1/cron/apply-scheduled-comp", "schedule": "0 15 * * *" },
    { "path": "/api/v1/cron/refresh-analytics-mv", "schedule": "0 18 * * *" },
    { "path": "/api/v1/cron/leave-promotion", "schedule": "0 2 * * *" },
    { "path": "/api/v1/cron/auto-acknowledge", "schedule": "0 * * * *" },
    { "path": "/api/v1/cron/overdue-check", "schedule": "30 * * * *" },
    { "path": "/api/v1/cron/eval-reminder", "schedule": "0 23 * * *" },
    { "path": "/api/v1/cron/org-snapshot", "schedule": "0 0 1 * *" }
  ]
}
